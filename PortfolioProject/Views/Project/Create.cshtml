@model Projects

<div class="container py-5">
    <div class="card">
        <div class="card-header">
            <h1 class="text-center">Create Project</h1>
        </div>
        <div class="card-body">
            <form method="post">
                <input asp-for="Id" hidden />
                <div class="row">
                    <!--For information-->
                    <div class="col-sm-8">
                        <div class="form-floating pb-2">
                            <input asp-for="Name" class="form-control"/>
                            <label asp-for="Name" class=" text-muted ms-2"></label>
                        </div>
                        <div class="form-floating pb-2">
                            <input asp-for="Description" class="form-control" />
                            <label asp-for="Description" class=" text-muted ms-2"></label>
                        </div>
                    </div>

                    <!--For pictures-->
                    <div class="col-sm-4">

                    </div>
                </div>
                <div class="row">
                    <button type="submit" class="btn btn-primary">Create</button>
                </div>
            </form>
        </div>
    </div>
</div>