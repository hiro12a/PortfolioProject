@model IEnumerable<Skills>

<div class="container py-5">
    <div class="card">
        <div class="card-header">
            <div class="row">
                <div class="col d-flex py-3">
                    <h1 class="">Skills/Certifications</h1>
                    <a class="btn btn-primary ms-auto align-items-center d-flex fs-5" asp-controller="Skills" asp-action="Upsert">Create Content<i class="bi bi-plus-circle ms-1"></i></a>
                </div>
            </div>
        </div>

        <!--Shows data-->
        <div class="card-body">
            <table class="table table-bordered table-striped">
                <thead>
                    <tr>
                        <td>Type</td>
                        <td>Name</td>
                        <td>Picture</td>
                        <td></td>
                    </tr>
                </thead>
                <tbody>
                    @foreach(var obj in Model)
                    {
                        <tr>
                            <td>@obj.type</td>
                            <td>@obj.name</td>

                            <!--Display image-->
                            <td style="width: 15%" >
                                @if(obj.ImageUrl != null)
                                {
                                    <img src="@obj.ImageUrl" class="w-100"/>
                                }
                                else
                                {
                                    <img src="https://placehold.co/500x600/png" style="width: 100%;"/>
                                }

                            </td>
                            <!--Edit and Delete Buttons-->
                            <td style="width:15%">                               
                                <a class="btn btn-primary" asp-controller="Skills" asp-action="Upsert" asp-route-id="@obj.Id">Edit</a>
                                <a class="btn btn-danger" asp-controller="Skills" asp-action="Delete" asp-route-id="@obj.Id">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody> 
            </table>
        </div>
    </div>
</div>