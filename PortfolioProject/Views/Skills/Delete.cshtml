@model Skills

<div class="container py-5">
    <div class="card">
        <div class="card-header text-center">
            <!--Check whether to use update or create by the id-->
            <h1 class="py-2">Delete Services</h1>
        </div>

        <div class="card-body">
            <!--encrypt allows us to use upload files-->
            <form method="post" enctype="multipart/form-data">
                <input asp-for="Id" hidden /> <!--Need this so the script can check what the id is-->
                <div class="row pb-2">
                    <!--For Inputing information-->
                    <div class="col-md-8">
                        <!--Type-->
                        <div class="form-floating pb-3">
                            <select asp-for="type" disabled  asp-items="@ViewBag.Types" class="form-control w-25">
                                <option disabled select>Select Type</option>
                            </select>
                            <label asp-for="type" class="">Type</label>
                        </div>
                        <!--Name-->
                        <div class="form-floating pb-3">
                            <input asp-for="name" disabled class="form-control" />
                            <label asp-for="name"></label>
                            <span asp-validation-for="name" class="text-danger"></span>
                        </div>
                        <!--Picture-->
                        <div class="form-floating">
                            <input asp-for="Pictures" disabled class="form-control border-0" />
                        </div>
                    </div>

                    <!--For displaying Image-->
                    <div class="col-sm-3">
                        <img src="@Model.ImageUrl" class="w-100" />
                    </div>
                </div>

                <!--For Submit-->
                <div class="row d-flex">
                    <div class="col-sm-6">
                        <button type="submit" class="btn btn-danger">Delete</button>

                        <!--Back Buttom-->
                        <a class="btn btn-secondary" asp-controller="Skills" asp-action="Index">Back to List</a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}